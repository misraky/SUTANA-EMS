# =====================================================
# SUTANA EMS BACKEND - ENVIRONMENT VARIABLES TEMPLATE
# =====================================================
# Copy this file to .env and update values
# =====================================================

# Node Environment (development | staging | production)
NODE_ENV=development
PORT=5000

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=sutana_ems
DB_POOL_MIN=10
DB_POOL_MAX=100

# =====================================================
# REDIS CONFIGURATION
# =====================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =====================================================
# JWT AUTHENTICATION
# =====================================================
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# =====================================================
# ENCRYPTION (AES-256 - 32 characters)
# =====================================================
ENCRYPTION_KEY=your_32_char_encryption_key_here

# =====================================================
# CORS CONFIGURATION
# =====================================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =====================================================
# FILE UPLOAD
# =====================================================
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf,application/msword

# =====================================================
# BANK INTEGRATIONS (Optional - set enabled=false if not used)
# =====================================================
CBE_API_ENABLED=false
CBE_API_ENDPOINT=https://sandbox.cbe.com.et/api
CBE_API_KEY=your_cbe_api_key
CBE_WEBHOOK_SECRET=your_webhook_secret

DASHEN_API_ENABLED=false
DASHEN_API_ENDPOINT=https://sandbox.dashenbank.et/api
DASHEN_API_KEY=your_dashen_api_key

AWASH_API_ENABLED=false
AWASH_API_ENDPOINT=https://sandbox.awashbank.com/api
AWASH_API_KEY=your_awash_api_key

TELEBIRR_API_ENABLED=false
TELEBIRR_API_ENDPOINT=https://sandbox.telebirr.et/api
TELEBIRR_API_KEY=your_telebirr_api_key

# =====================================================
# SMS INTEGRATION (Africa's Talking)
# =====================================================
AFRICA_TALKING_ENABLED=true
AFRICA_TALKING_API_ENDPOINT=https://api.africastalking.com/version1
AFRICA_TALKING_API_KEY=your_africastalking_api_key
AFRICA_TALKING_USERNAME=sandbox
AFRICA_TALKING_SENDER_ID=SutanaEMS

# =====================================================
# EMAIL INTEGRATION (SendGrid)
# =====================================================
SENDGRID_ENABLED=true
SENDGRID_API_ENDPOINT=https://api.sendgrid.com/v3
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@sutana.com
SENDGRID_FROM_NAME=Sutana EMS

# =====================================================
# BACKUP CONFIGURATION
# =====================================================
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_BUCKET_NAME=sutana-backups

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=info
LOG_DIR=./logs

# =====================================================
# RATE LIMITING (requests per minute)
# =====================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================
# SESSION & SECURITY
# =====================================================
SESSION_TIMEOUT_MINUTES=30
MAX_CONCURRENT_SESSIONS=3
MAX_FAILED_ATTEMPTS=5
LOCKOUT_MINUTES=15

# =====================================================
# BUSINESS RULES
# =====================================================
TAX_RATE=15
CASHIER_MAX_DISCOUNT=5
MANAGER_MAX_DISCOUNT=15
CEO_MAX_DISCOUNT=25
HIGH_VALUE_PO_THRESHOLD=200000