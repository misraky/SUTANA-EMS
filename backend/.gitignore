# =====================================================
# SUTANA EMS - BACKEND .gitignore
# =====================================================

# ---------------------------
# Environment Variables
# ---------------------------
.env
.env.*
!.env.example
.env.local
.env.development
.env.staging
.env.production
.env.test

# ---------------------------
# Dependencies
# ---------------------------
node_modules/

# ---------------------------
# Logs
# ---------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
pm2-*.log

# ---------------------------
# Runtime / PIDs
# ---------------------------
pids/
*.pid
*.pid.lock
*.seed

# ---------------------------
# Lock Files
# ---------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---------------------------
# Build Outputs
# ---------------------------
dist/
build/
out/
.cache/
.parcel-cache/

# ---------------------------
# Test & Coverage
# ---------------------------
coverage/
.nyc_output/
*.lcov
.jest/

# ---------------------------
# Uploads & User Files
# ---------------------------
uploads/
attachments/
receipts/
invoices/
temp_uploads/
public/uploads/

# ---------------------------
# Backups & Database Dumps
# ---------------------------
backups/
backups_dev/
backups_staging/
*.sql
*.sql.gz
*.sql.zip

# ---------------------------
# Database Files
# ---------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal
dump.rdb
appendonly.aof
mysql-bin.*
binlog.*

# ---------------------------
# SSL / Certificates / Keys
# ---------------------------
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.cer
*.der

# ---------------------------
# Secrets & Credentials
# ---------------------------
*.json.encrypted
*.key.json
*.secret.json
service-account.json
credentials.json
.secret/
secrets.yaml
*.secret.yaml
*.vault.yml
vault.pass

# ---------------------------
# Archives
# ---------------------------
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tgz
*.gz
*.bz2

# ---------------------------
# TypeScript
# ---------------------------
*.tsbuildinfo

# ---------------------------
# Editor & IDE
# ---------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ---------------------------
# OS Files
# ---------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.dll

# ---------------------------
# Temporary / Scratch Files
# ---------------------------
tmp/
temp/
scratch/
*.tmp
*.temp
.temp/
# One-off debug/test scripts in root
check-*.js
test-*.js
update-*.js
fix-*.js
seed-*.js
migrate-*.js

# ---------------------------
# Docker
# ---------------------------
docker-compose.override.yml
Dockerfile.dev

# ---------------------------
# PM2
# ---------------------------
.pm2/
pm2.pid

# ---------------------------
# Infrastructure (CI/CD, K8s, Terraform)
# ---------------------------
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
*.tfvars.json
.terraform.lock.hcl
*.retry

# ---------------------------
# GitHub Actions Secrets
# ---------------------------
.github/workflows/*.secret.yml

# ---------------------------
# Misc
# ---------------------------
.eslintcache
.prettiercache
metrics.json
health.json
status.json
NOTES.md
TODO.md
TEMP.md
scratchpad.md