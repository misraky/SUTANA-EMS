# =====================================================
# SUTANA EMS - FRONTEND .gitignore
# =====================================================

# ---------------------------
# Environment Variables
# ---------------------------
.env
.env.*
!.env.example
.env.local
.env.development
.env.staging
.env.production

# ---------------------------
# Dependencies
# ---------------------------
node_modules/

# ---------------------------
# Lock Files
# ---------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---------------------------
# Build Outputs
# ---------------------------
dist/
dist-ssr/
build/
out/
.cache/
.parcel-cache/
.vite/

# ---------------------------
# Logs
# ---------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------
# Test & Coverage
# ---------------------------
coverage/
.nyc_output/
*.lcov
.jest/

# ---------------------------
# Static Uploads
# ---------------------------
public/uploads/
public/temp/

# ---------------------------
# TypeScript
# ---------------------------
*.tsbuildinfo

# ---------------------------
# Editor & IDE
# ---------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln
*.sublime-project
*.sublime-workspace

# ---------------------------
# OS Files
# ---------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ---------------------------
# Temporary Files
# ---------------------------
tmp/
temp/
scratch/
*.tmp
*.temp

# ---------------------------
# Misc
# ---------------------------
.eslintcache
.prettiercache
NOTES.md
TODO.md
TEMP.md
scratchpad.md
